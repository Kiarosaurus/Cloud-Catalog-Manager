# ==========================================
# PLANTILLA .env  (copiar a .env y rellenar)
# NO contiene secretos reales. El .env real NO se commitea.
# ==========================================

# ---- AWS S3 (Credenciales Temporales de AWS Academy) ----
# Repegar los 3 valores en CADA sesión de Academy (el token caduca).
AWS_ACCESS_KEY_ID="ASIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_SESSION_TOKEN="..."
AWS_REGION="us-east-1"
S3_BUCKET_NAME="s14lab-bucket"

# ---- Base de Datos ----
# Local (docker-compose): host = nombre del service 'db'
# Producción (RDS): reemplazar host por el endpoint del RDS
DATABASE_URL="postgresql://admin:admin123@db:5432/catalogo"

# ---- Seguridad Backend ----
JWT_SECRET="cambia_esta_clave_secreta"

# ---- docker-compose (deben coincidir con DATABASE_URL) ----
POSTGRES_USER="admin"
POSTGRES_PASSWORD="admin123"
POSTGRES_DB="catalogo"

# ---- Frontend ----
VITE_API_URL="http://localhost:8000"

# ---- Usuario Admin inicial (seed) ----
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
